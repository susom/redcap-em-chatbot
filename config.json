{
    "name": "Cappy - REDCap Chat Bot",

    "namespace": "Stanford\\REDCapChatBot",

    "description": "Cappy is an EM enabled system-wide to inject and manage frontend support chatbot functionality across all REDCap pages.",


    "documentation": "README.md",

    "authors": [
        {
            "name": "Irvin Szeto",
            "email": "irvins@stanford.edu",
            "institution": "Stanford University"
        }
    ],

    "framework-version": 14,

    "enable-every-page-hooks-on-system-pages": true,

    "links": {
        "project": [
            {
                "name": "Standalone Project Chatbot",
                "icon": "fa-solid fa-robot",
                "url": "pages/standalone_chat.php",
                "show-header-and-footer": false
            }
        ],
        "control-center": [
            {
                "name": "Cappy/RAG : EM Project Check (all time)",
                "icon": "fas fa-info-circle",
                "url" : "cron/check_em_project.php",
                "show-header-and-footer": false
            },
            {
                "name": "Cappy/RAG : Current JQL",
                "icon": "fas fa-info-circle",
                "url" : "cron/check_rssd_completions.php",
                "show-header-and-footer": false
            },
            {
                "name": "Cappy/RAG : MedWiki Scrape (all time)",
                "icon": "fas fa-info-circle",
                "url" : "cron/check_med_wiki.php",
                "show-header-and-footer": false
            },
            {
                "name": "Cappy/RAG : Community Portal Scrape (all time)",
                "icon": "fas fa-info-circle",
                "url" : "cron/check_community_portal.php",
                "show-header-and-footer": false
            }

        ]
    },

    "no-auth-pages": [],

    "auth-ajax-actions": [
        "callAI"
    ],

    "no-auth-ajax-actions": [],

    "project-settings": [
        {
            "key": "project_chatbot_title",
            "name": "Project Chatbot Title",
            "required": false,
            "type": "text"
        },
        {
            "key": "agent_mode",
            "name": "<b>Enable Agent Mode</b><br><i>(experimental)</i> Allows the chatbot to use multi-step agentic workflows with tool execution.",
            "required": false,
            "type": "checkbox"
        },
        {
            "key": "project_chatbot_intro",
            "name": "Chat Intro Messaging",
            "required": false,
            "type": "textarea"
        },
        {
            "key": "project_chat_initiator",
            "name": "<b>Preemptive Greeting Prompt</b><br><i>(optional)</i> When set, this invisible prompt is sent the moment a user opens the chat from the badge at the <b>start of a session</b>, so Cappy appears to greet them proactively. The prompt itself is hidden; only Cappy's reply is shown. Leave blank to disable.",
            "required": false,
            "type": "textarea"
        },
        {
            "key": "project_allowed_context_namespaces",
            "name": "Allowed context namespaces for postMessage injection (comma separated, e.g. rexi-dashboard, rexi-project, rexi-memory)",
            "required": false,
            "type": "textarea"
        },
        {
            "key": "project_expanded_width",
            "name": "Expanded Chatbot Width (%/px)",
            "required": false,
            "type": "text"
        },
        {
            "key": "project_expanded_height",
            "name": "Expanded Chatbot Height (%/px)",
            "required": false,
            "type": "text"
        },
        {
            "key": "hide_message_meta",
            "name": "Don't show token usage or vote thumbs",
            "required": false,
            "type": "checkbox"
        },
        {
            "key": "project_chatbot_system_context",
            "name": "Raw text to inject into system context for Cappy",
            "required": false,
            "type": "textarea"
        },
        {
            "key": "project_escalation_prompt_guidance",
            "name": "Escalation prompt guidance (optional)",
            "required": false,
            "type": "textarea"
        },
        {
            "key": "project_chatbot_custom_css",
            "name": "Custom CSS for Standalone Chatbot",
            "required": false,
            "type": "textarea"
        },
        {
            "key": "inject-project-metadata",
            "name": "<b>Inject Project Metadata into System Prompt</b><br><i>(optional)</i> Adds full REDCap project metadata to the prompt. Can be large — useful for debugging or development.",
            "required": false,
            "type": "checkbox"
        },
        {
            "key": "project-llm-model",
            "name": "LLM Model",
            "required": false,
            "type": "dropdown",
            "choices": [
                {
                    "value": "gpt-4-1",
                    "name": "GPT-4.1"
                },
                {
                    "value": "gpt-4-1-nano",
                    "name": "GPT-4.1 Nano"
                },
                {
                    "value": "gpt-5-4",
                    "name": "GPT-5.4"
                },
                {
                    "value": "gpt-5-4-nano",
                    "name": "GPT-5.4 Nano"
                },
                {
                    "value": "o3",
                    "name": "o3"
                },
                {
                    "value": "o4-mini",
                    "name": "o4-mini"
                },
                {
                    "value": "claude-sonnet-4.6",
                    "name": "Claude Sonnet 4.6"
                },
                {
                    "value": "claude-opus-4-7",
                    "name": "Claude Opus 4.7"
                },
                {
                    "value": "deepseek-r1",
                    "name": "DeepSeek R1"
                },
                {
                    "value": "gemini-2.5-flash",
                    "name": "Gemini 2.5 Flash"
                },
                {
                    "value": "gemini-2.5-pro",
                    "name": "Gemini 2.5 Pro"
                }
            ],
            "default": "gpt-4-1"
        },
        {
            "key": "project-gpt-temperature",
            "name": "GPT Temperature",
            "required": false,
            "type": "number",
            "default": 0.7
        },
        {
            "key": "project-gpt-top-p",
            "name": "GPT Top P",
            "required": false,
            "type": "number",
            "default": 0.9
        },
        {
            "key": "project-gpt-frequency-penalty",
            "name": "GPT Frequency Penalty",
            "required": false,
            "type": "number",
            "default": 0.5
        },
        {
            "key": "project-gpt-presence-penalty",
            "name": "GPT Presence Penalty",
            "required": false,
            "type": "number",
            "default": 0
        },
        {
            "key": "project-gpt-max-tokens",
            "name": "GPT Max Tokens",
            "required": false,
            "type": "number",
            "default": 800
        },
        {
            "key": "project-reasoning-effort",
            "name": "<b>Reasoning Effort</b>  <br>(only applicable to o3, o4-mini reasoning models)",
            "required": false,
            "type": "dropdown",
            "choices": [
                {
                    "value": "low",
                    "name": "low"
                },
                {
                    "value": "medium",
                    "name": "medium"
                },
                {
                    "value": "high",
                    "name": "high"
                }
            ],
            "default": "medium"
        },
        {
            "key": "enable-project-debug-logging",
            "name": "<b>Enable Debug Logging</b><br><i>(optional)</i> Requires installation and configuration of emLogger",
            "required": false,
            "type": "checkbox"
        }
    ],

