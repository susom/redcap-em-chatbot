    "crons": [
        {
            "cron_name": "daily_context_pull",
            "cron_description": "Cappy's daily cron job to fetch new or updated context and add it to the Support Context DB.",
            "method": "dailyCronRun",
            "cron_frequency": "86400",
            "cron_max_run_time": "3600"
        }
    ],

    "compatibility": {
        "php-version-min": "",
        "php-version-max": "",
        "redcap-version-min": "",
        "redcap-version-max": ""
    }
